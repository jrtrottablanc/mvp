				--define stepDir=${stepDir} \
				--define input=${BCAM} \
				--define levelId=${sample} \
				${ttDir}/${igvcram_tt} > ${jobCmd}
				igvcramJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${igvcramJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - igvcram directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
			
		#--------------#
		# bamtocram    #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " bamtocram " ]]; then
			echo "# INFO - Submitting bamtocram for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/bamtocram/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.bamtocram"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				BCAMname=$(basename "${BCAM}")
				BCAMext="${BCAMname##*.}"
				if [ "${BCAMext}" = "bam" ]; then
					apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
					--define qos=${bamtocram_qos} \
					--define cpu=${bamtocram_cpu} \
					--define mem=${bamtocram_mem} \
					--define time="${bamtocram_time}" \
					--define excludeNode=[% excludeNode %] \
					--define jobLab=${jobLab} \
					--define confFile=[% confFile %] \
					--define stepDir=${stepDir} \
					--define input=${BCAM%.bam} \
					--define levelId=${sample} \
					${ttDir}/${bamtocram_tt} > ${jobCmd}
					bamtocramJobID=$(sbatch --parsable ${jobCmd})
					if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
					echo -e "${jobCmd}\t${bamtocramJobID}" | tee -a ${jobLog} >&2
				else
					echo "# INFO - Alignments are already in CRAM format, skipping bamtocram for sample [${sample}]" | tee -a ${stepDir}/bamtocram.log >&2
				fi
			else
				echo "# INFO - bamtocram directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		
		#-----------------#
		# gutierrezsarprs #
		#-----------------#
