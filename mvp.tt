			stepDir="${pedDir}/ehlong/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.ehlong"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${ehlong_qos} \
				--define cpu=${ehlong_cpu} \
				--define mem=${ehlong_mem} \
				--define time="${ehlong_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define input=${BCAM} \
				--define levelId=${sample} \
				--define ehCatalog=${ehlongCatalog} \
				--define ehSuffix="expansionhunter.longcatalog" \
				${ttDir}/${expansionhunter_tt} > ${jobCmd}
				ehlongJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${ehlongJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - ehlong directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		
		#--------------#
		# hlahd        #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " hlahd " ]]; then
			echo "# INFO - Submitting hlahd for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/hlahd/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				if [ "${app}" = "WGS" ]; then
					jobLab="${sample}.hlahd"
					jobCmd="${stepDir}/${jobLab}.cmd"
					jobLog="${stepDir}/${jobLab}.jobID.log"
					apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
					--define qos=${hlahd_qos} \
					--define cpu=${hlahd_cpu} \
					--define mem=${hlahd_mem} \
					--define time="${hlahd_time}" \
					--define excludeNode=[% excludeNode %] \
					--define jobLab=${jobLab} \
					--define confFile=[% confFile %] \
					--define stepDir=${stepDir} \
					--define input=${BCAM} \
					--define levelId=${sample} \
					${ttDir}/${hlahd_tt} > ${jobCmd}
					hlahdJobID=$(sbatch --parsable ${jobCmd})
					if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
					echo -e "${jobCmd}\t${hlahdJobID}" | tee -a ${jobLog} >&2
				else
					echo "# INFO - HLA-HD available only for WGS, application is [${app}], skipping hlahd for sample [${sample}]" | tee -a ${stepDir}/hlahd.log >&2
				fi
			else
				echo "# INFO - hlahd directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		
		#--------------#
		# hlakir       #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " hlakir " ]]; then
			echo "# INFO - Submitting hlakir for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/hlakir/${sample}"
