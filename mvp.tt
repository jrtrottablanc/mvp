#!/bin/bash
#SBATCH --exclude=[% excludeNode %]
#SBATCH --job-name=[% jobLab %]
#SBATCH --chdir=[% anaDir %]
#SBATCH --partition=genD
#SBATCH --requeue
#SBATCH --output=[% jobLab %]_%j.out 
#SBATCH --error=[% jobLab %]_%j.err 
#SBATCH --ntasks=1
#SBATCH --qos=[% qos %]
#SBATCH --cpus-per-task=[% cpu %]
#SBATCH --mem-per-cpu=[% mem %]
#SBATCH --time=[% time %]

hostname >&2
printf START >&2; uptime >&2
date >&2

export LC_ALL=C

cmdFile="[% anaDir %]/[% jobLab %].cmd"
errLog="[% anaDir %]/ERROR.log"

source [% confFile %]

echo "# INFO - Pipeline configuration" >&2
echo "[% confFile %]" >&2

echo "# INFO - Step(s) required" >&2
echo "[% step %]" >&2
IFS=',' read -r -a stepuser <<< "[% step %]"

################################################
# PEDIGREE/SAMPLE STRUCTURE, SHEET & PED       #
################################################
# (https://gatk.broadinstitute.org/hc/en-us/articles/360035531972-PED-Pedigree-format)
echo "# INFO - Generating samples_info, samples_rawdata and PED file by pedigree and by sample ..." >&2
while read pedigree; do
	pedDir="[% anaDir %]/${pedigree}"
	
	#~ if [ ! -f ${pedDir}/${pedigree}_samples_info.tsv ]; then
		echo -e "#pedigree\tsample\tsampleName\tsex\tsampleStatus\tsubproject\tapp\tmotherId\tfatherId\tbamcram\tgvcf\tvcf" > ${pedDir}/${pedigree}_samples_info.tsv
		grep "^${pedigree}\s" [% analysisId %]_samples_info.tsv >> ${pedDir}/${pedigree}_samples_info.tsv
		if [ $? != 0 ]; then echo "ERROR : Cannot generate samples_info for pedigree [${pedigree}] [${cmdFile}]" >> ${errLog}; exit 1; fi
		
		echo -e "#pedigree\tsample\tapp\tsex\tbamcram\tgvcf\tvcf" > ${pedDir}/${pedigree}_samples_rawdata.tsv
		grep "^${pedigree}\s" [% analysisId %]_samples_rawdata.tsv >> ${pedDir}/${pedigree}_samples_rawdata.tsv
		if [ $? != 0 ]; then echo "ERROR : Cannot generate samples_rawdata for pedigree [${pedigree}] [${cmdFile}]" >> ${errLog}; exit 1; fi
		
		grep -v "^#" ${pedDir}/${pedigree}_samples_info.tsv | awk '{print $1"\t"$2"\t"$9"\t"$8"\t"$4"\t"$5}' \
		> ${pedDir}/${pedigree}_samples_info.ped
		if [ $? != 0 ]; then echo "ERROR : Cannot generate PED file for pedigree [${pedigree}] [${cmdFile}]" >> ${errLog}; exit 1; fi
	#~ fi
	
	while read ped sample app sex BCAM GVCF VCF; do
		#~ if [ ! -f ${pedDir}/${sample}_samples_info.tsv ]; then
			echo -e "#pedigree\tsample\tsampleName\tsex\tsampleStatus\tsubproject\tapp\tmotherId\tfatherId\tbamcram\tgvcf\tvcf" > ${pedDir}/${sample}_samples_info.tsv
			grep "\s${sample}\s" [% analysisId %]_samples_info.tsv >> ${pedDir}/${sample}_samples_info.tsv
			if [ $? != 0 ]; then echo "ERROR : Cannot generate samples_info for sample [${sample}] [${cmdFile}]" >> ${errLog}; exit 1; fi
			
			echo -e "#pedigree\tsample\tapp\tsex\tbamcram\tgvcf\tvcf" > ${pedDir}/${sample}_samples_rawdata.tsv
			grep "\s${sample}\s" [% analysisId %]_samples_rawdata.tsv >> ${pedDir}/${sample}_samples_rawdata.tsv
			if [ $? != 0 ]; then echo "ERROR : Cannot generate samples_rawdata for sample [${sample}] [${cmdFile}]" >> ${errLog}; exit 1; fi
		#~ fi
	done < <(grep -v "^#" ${pedDir}/${pedigree}_samples_rawdata.tsv)
	
done < <(grep -v "^#" [% analysisId %]_samples_info.tsv | cut -f 1 | sort -u)

cat */*ped > [% analysisId %]_samples_info.ped

################################################
# SUBMIT PER PEDIGREE AND SAMPLE               #
################################################
echo "# INFO - Submitting analysis by pedigree ..." >&2
unset allhapcallJobIDs
while read pedigree; do
	pedDir="[% anaDir %]/${pedigree}"
	
	################################################
	# SUBMIT SAMPLE                                #
	################################################
	unset hapcallJobIDs
	while read ped sample app sex BCAM GVCF VCF; do
		
		#-----------------#
		# hapcallgenonorm #
		#-----------------#
		if [[ " ${stepuser[*]} " =~ " singshortvar " ]] || [[ " ${stepuser[*]} " =~ " multshortvar " ]] || [[ " ${stepuser[*]} " =~ " allshortvar " ]] || [[ " ${stepuser[*]} " =~ " roh " ]]; then
			echo "# INFO - Submitting hapcall, genogvcf and bcfnorm by chromosome for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			unset hapcallgenonormJobIDs
			stepDir="${pedDir}/hapcallgenonorm/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				for chr in ${chrList}; do
					if [ -f ${pedDir}/rawdata/${sample}/${sample}.${chr}.g.vcf.gz ]; then
						ln -s ${pedDir}/rawdata/${sample}/${sample}.${chr}.g.vcf.gz ${stepDir}/${sample}.${chr}.g.vcf.gz
						ln -s ${pedDir}/rawdata/${sample}/${sample}.${chr}.g.vcf.gz.tbi ${stepDir}/${sample}.${chr}.g.vcf.gz.tbi
					fi
					if [ -f ${pedDir}/rawdata/${sample}/${sample}.${chr}.g.geno.vcf.gz ]; then
						ln -s ${pedDir}/rawdata/${sample}/${sample}.${chr}.g.geno.vcf.gz ${stepDir}/${sample}.${chr}.g.geno.vcf.gz
						ln -s ${pedDir}/rawdata/${sample}/${sample}.${chr}.g.geno.vcf.gz.tbi ${stepDir}/${sample}.${chr}.g.geno.vcf.gz.tbi
					fi
					jobLab="${sample}_${chr}.hapcallgenonorm"
					jobCmd="${stepDir}/${jobLab}.cmd"
					jobLog="${stepDir}/${jobLab}.jobID.log"
					apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
					--define qos=${hapcallgenonorm_qos} \
					--define cpu=${hapcallgenonorm_cpu} \
					--define mem=${hapcallgenonorm_mem} \
					--define time="${hapcallgenonorm_time}" \
					--define excludeNode=[% excludeNode %] \
					--define jobLab=${jobLab} \
					--define stepDir=${stepDir} \
					--define confFile=[% confFile %] \
					--define input=${BCAM} \
					--define chr=${chr} \
					--define levelId=${sample} \
					${ttDir}/${hapcallgenonorm_tt} > ${jobCmd}
					hapcallgenonormJobID=$(sbatch --parsable ${jobCmd})
					hapcallgenonormJobIDs+=($(echo "${hapcallgenonormJobID}"))
					hapcallJobIDs+=($(echo "${hapcallgenonormJobID}"))
					allhapcallJobIDs+=($(echo "${hapcallgenonormJobID}"))
					if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
					echo -e "${jobCmd}\t${hapcallgenonormJobID}" | tee -a ${jobLog} >&2
					
				done
			else
				echo "# INFO - hapcallgenonorm directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		hapcallgenonormJobID=$(IFS=: ; echo "${hapcallgenonormJobIDs[*]}")
			
		#-------------------#
		# gathervcfpreannot #
		#-------------------#
		if [[ " ${stepuser[*]} " =~ " singshortvar " ]] || [[ " ${stepuser[*]} " =~ " roh " ]]; then
			echo "# INFO - Submitting gathervcfpreannot for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/gathervcfpreannot/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir} >&2
				jobLab="${sample}.gathervcfpreannot"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${gathervcf_qos} \
				--define cpu=${gathervcf_cpu} \
				--define mem=${gathervcf_mem} \
				--define time="${gathervcf_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define stepDir=${stepDir} \
				--define confFile=[% confFile %] \
				--define pedDir=${pedDir} \
				--define levelId=${sample} \
				--define inputDir=${pedDir}/hapcallgenonorm/${sample} \
				--define fileSuffix="g.geno.norm.vcf.gz" \
				--define chrList="${chrList}" \
				${ttDir}/${gathervcf_tt} > ${jobCmd}
				if [ ! -z "${hapcallgenonormJobID}" ]; then
					gathervcfpreannotJobID=$(sbatch --dependency=afterok:${hapcallgenonormJobID} --parsable ${jobCmd})
				else
					gathervcfpreannotJobID=$(sbatch --parsable ${jobCmd})
				fi
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t$gathervcfpreannotJobID" | tee -a ${jobLog} >&2
			else
				echo "# INFO - gathervcfpreannot directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
			
		#--------------#
		# singshortvar #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " singshortvar " ]]; then
			echo "# INFO - Submitting singshortvar for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/singshortvar/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.singshortvar"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${singshortvar_qos} \
				--define cpu=${singshortvar_cpu} \
				--define mem=${singshortvar_mem} \
				--define time="${singshortvar_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define pedDir=${pedDir} \
				--define stepDir=${stepDir} \
				--define levelId=${sample} \
				--define app="${app}" \
				--define gathervcfpreannotJobID=${gathervcfpreannotJobID} \
				${ttDir}/${singshortvar_tt} > ${jobCmd}
				if [ ! -z "${hapcallgenonormJobID}" ]; then
					singshortJobID=$(sbatch --dependency=afterok:${hapcallgenonormJobID} --parsable ${jobCmd})
				else
					singshortJobID=$(sbatch --parsable ${jobCmd})
				fi
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${singshortJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - singshortvar directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
			
		#--------------#
		# mt           #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " mt " ]]; then
			echo "# INFO - Submitting mt for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/mt/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.mt"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${mt_qos} \
				--define cpu=${mt_cpu} \
				--define mem=${mt_mem} \
				--define time="${mt_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define input=${BCAM} \
				--define levelId=${sample} \
				${ttDir}/${mt_tt} > ${jobCmd}
				mtJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${mtJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - mt directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
			
		#------------------#
		# roh              #
		#------------------#
		if [[ " ${stepuser[*]} " =~ " roh " ]]; then
			echo "# INFO - Submitting roh for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/roh/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.roh"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${roh_qos} \
				--define cpu=${roh_cpu} \
				--define mem=${roh_mem} \
				--define time="${roh_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define input=${pedDir}/gathervcfpreannot/${sample}/${sample}.allchr.g.geno.norm.vcf.gz \
				--define levelId=${sample} \
				${ttDir}/${roh_tt} > ${jobCmd}
				if [ ! -z "${gathervcfpreannotJobID}" ]; then
					rohJobID=$(sbatch --dependency=afterok:${gathervcfpreannotJobID} --parsable ${jobCmd})
				else
					rohJobID=$(sbatch --parsable ${jobCmd})
				fi
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${rohJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - roh directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
			
		#--------------#
		# singmanta    #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " singmanta " ]]; then
			echo "# INFO - Submitting singmanta for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/singmanta/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.singmanta"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${singmanta_qos} \
				--define cpu=${singmanta_cpu} \
				--define mem=${singmanta_mem} \
				--define time="${singmanta_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define input=${BCAM} \
				--define levelId=${sample} \
				--define app="${app}" \
				${ttDir}/${singmanta_tt} > ${jobCmd}
				singmantaJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${singmantaJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - singmanta directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		
		#--------------#
		# clinsv       #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " clinsv " ]]; then
			echo "# INFO - Submitting clinsv for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/clinsv/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				if [ "${app}" = "WGS" ]; then
					jobLab="${sample}.clinsv"
					jobCmd="${stepDir}/${jobLab}.cmd"
					jobLog="${stepDir}/${jobLab}.jobID.log"
					apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
					--define qos=${clinsv_qos} \
					--define cpu=${clinsv_cpu} \
					--define mem=${clinsv_mem} \
					--define time="${clinsv_time}" \
					--define excludeNode=[% excludeNode %] \
					--define jobLab=${jobLab} \
					--define confFile=[% confFile %] \
					--define stepDir=${stepDir} \
					--define input=${BCAM} \
					--define levelId=${sample} \
					${ttDir}/${clinsv_tt} > ${jobCmd}
					clinsvJobID=$(sbatch --parsable ${jobCmd})
					if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
					echo -e "${jobCmd}\t${clinsvJobID}" | tee -a ${jobLog} >&2
				else
					echo "# INFO - clinsv available only for WGS, application is [${app}], skipping clinsv for sample [${sample}]" | tee -a ${stepDir}/clinsv.log >&2
				fi
			else
				echo "# INFO - clinsv directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		
		#--------------#
		# freec        #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " freec " ]]; then
			echo "# INFO - Submitting freec for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/freec/${sample}"
			if [ "${app}" = "WGS" ]; then
				for windowSize in 5000 20000 50000; do
					if [ ! -d ${stepDir}/${windowSize} ]; then
						mkdir -p ${stepDir}/${windowSize}
						jobLab="${sample}.freec.${windowSize}"
						jobCmd="${stepDir}/${windowSize}/${jobLab}.cmd"
						jobLog="${stepDir}/${windowSize}/${jobLab}.jobID.log"
						apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
						--define qos=${freecrun_qos} \
						--define cpu=${freecrun_cpu} \
						--define mem=${freecrun_mem} \
						--define time="${freecrun_time}" \
						--define excludeNode=[% excludeNode %] \
						--define jobLab=${jobLab} \
						--define confFile=[% confFile %] \
						--define stepDir=${stepDir}/${windowSize} \
						--define input=${BCAM} \
						--define levelId=${sample} \
						--define sex=${sex} \
						--define app="${app}" \
						--define windowSize=${windowSize} \
						${ttDir}/${freecrun_tt} > ${jobCmd}
						freecrunJobID=$(sbatch --parsable ${jobCmd})
						if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
						echo -e "${jobCmd}\t${freecrunJobID}" | tee -a ${jobLog} >&2
					else
						echo "# INFO - freec directory for pedigree [${pedigree}], sample [${sample}] and windowSize [${windowSize}] already exists, skipping this step" >&2
					fi
				done
			else
				windowSize=0
				if [ ! -d ${stepDir}/${windowSize} ]; then
					mkdir -p ${stepDir}/${windowSize}
					jobLab="${sample}.freec.${windowSize}"
					jobCmd="${stepDir}/${windowSize}/${jobLab}.cmd"
					jobLog="${stepDir}/${windowSize}/${jobLab}.jobID.log"
					apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
					--define qos=${freecrun_qos} \
					--define cpu=${freecrun_cpu} \
					--define mem=${freecrun_mem} \
					--define time="${freecrun_time}" \
					--define excludeNode=[% excludeNode %] \
					--define jobLab=${jobLab} \
					--define confFile=[% confFile %] \
					--define stepDir=${stepDir}/${windowSize} \
					--define input=${BCAM} \
					--define levelId=${sample} \
					--define sex=${sex} \
					--define app="${app}" \
					--define windowSize=${windowSize} \
					${ttDir}/${freecrun_tt} > ${jobCmd}
					freecrunJobID=$(sbatch --parsable ${jobCmd})
					if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
					echo -e "${jobCmd}\t${freecrunJobID}" | tee -a ${jobLog} >&2
				else
					echo "# INFO - freec directory for pedigree [${pedigree}], sample [${sample}] and windowSize [${windowSize}] already exists, skipping this step" >&2
				fi
			fi
		fi
			
		#--------------#
		# smafind      #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " smafind " ]]; then
			echo "# INFO - Submitting smafind for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/smafind/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.smafind"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${smafind_qos} \
				--define cpu=${smafind_cpu} \
				--define mem=${smafind_mem} \
				--define time="${smafind_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define input=${BCAM} \
				--define levelId=${sample} \
				${ttDir}/${smafind_tt} > ${jobCmd}
				smafindJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${smafindJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - smafind directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		
		#--------------#
		# smncall      #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " smncall " ]]; then
			echo "# INFO - Submitting smncall for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/smncall/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.smncall"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${smncall_qos} \
				--define cpu=${smncall_cpu} \
				--define mem=${smncall_mem} \
				--define time="${smncall_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define input=${BCAM} \
				--define levelId=${sample} \
				${ttDir}/${smncall_tt} > ${jobCmd}
				smncallJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${smncallJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - smncall directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		
		#--------------#
		# cyrius       #
		#--------------#
		if [[ " ${stepuser[*]} " =~ " cyrius " ]]; then
			echo "# INFO - Submitting cyrius for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/cyrius/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.cyrius"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
