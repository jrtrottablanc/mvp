			echo "# INFO - Submitting gutierrezsarprs for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/gutierrezsarprs/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.gutierrezsarprs"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${gutierrezsarprs_qos} \
				--define cpu=${gutierrezsarprs_cpu} \
				--define mem=${gutierrezsarprs_mem} \
				--define time="${gutierrezsarprs_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define input=${BCAM} \
				--define levelId=${sample} \
				${ttDir}/${gutierrezsarprs_tt} > ${jobCmd}
				gutierrezsarprsJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${gutierrezsarprsJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - gutierrezsarprs directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi
		
		#-----------------#
		# tegerpgxgeno    #
		#-----------------#
		if [[ " ${stepuser[*]} " =~ " tegerpgxgeno " ]]; then
			echo "# INFO - Submitting tegerpgxgeno for pedigree [${pedigree}] and sample [${sample}] ..." >&2
			stepDir="${pedDir}/tegerpgxgeno/${sample}"
			if [ ! -d ${stepDir} ]; then
				mkdir -p ${stepDir}
				jobLab="${sample}.tegerpgxgeno"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--tag_style=php \
				--define qos=${tegerpgxgeno_qos} \
				--define cpu=${tegerpgxgeno_cpu} \
				--define mem=${tegerpgxgeno_mem} \
				--define time="${tegerpgxgeno_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define input=${BCAM} \
				--define levelId=${sample} \
				${ttDir}/${tegerpgxgeno_tt} > ${jobCmd}
				tegerpgxgenoJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${tegerpgxgenoJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - tegerpgxgeno directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
			fi
		fi

	done < <(grep -v "^#" ${pedDir}/${pedigree}_samples_rawdata.tsv)
	hapcallJobID=$(IFS=: ; echo "${hapcallJobIDs[*]}")
	
	################################################
	# SUBMIT PER PEDIGREE                          #
	################################################
	nSampPed=$(grep -v "^#" ${pedDir}/${pedigree}_samples_info.tsv | wc -l)
	app=$(grep -v "^#" [% analysisId %]_samples_rawdata.tsv | cut -f 3 | sort -u)
	
	#--------------#
	# multshortvar #
	#--------------#
	if [[ " ${stepuser[*]} " =~ " multshortvar " ]]; then
		echo "# INFO - Submitting multshortvar for pedigree [${pedigree}] ..." >&2
		stepDir="${pedDir}/multshortvar"
		if [ ! -d ${stepDir} ]; then
			mkdir -p ${stepDir}
			if [ "$nSampPed" -gt "1" ]; then
				jobLab="${pedigree}.multshortvar"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${multshortvar_qos} \
				--define cpu=${multshortvar_cpu} \
				--define mem=${multshortvar_mem} \
				--define time="${multshortvar_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define pedDir=${pedDir} \
				--define stepDir=${stepDir} \
				--define levelId=${pedigree} \
				--define app="${app}" \
				${ttDir}/${multshortvar_tt} > ${jobCmd}
				if [ ! -z  "${hapcallJobID}" ]; then
					multshortJobID=$(sbatch --dependency=afterok:${hapcallJobID} --parsable ${jobCmd})
				else
					multshortJobID=$(sbatch --parsable ${jobCmd})
				fi
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${multshortJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - Only one sample for this pedigree [${pedigree}], skipping multshortvar" | tee -a ${stepDir}/multshortvar.log >&2
			fi
		else
			echo "# INFO - multshortvar directory for pedigree [${pedigree}] already exists, skipping this step" >&2
		fi
	fi
	
	#--------------#
	# multmanta    #
	#--------------#
	if [[ " ${stepuser[*]} " =~ " multmanta " ]]; then
		echo "# INFO - Submitting multmanta for pedigree [${pedigree}] ..." >&2
		stepDir="${pedDir}/multmanta"
		if [ ! -d ${stepDir} ]; then
			mkdir -p ${stepDir}
			if [ "$nSampPed" -gt "1" ]; then
				jobLab="${pedigree}.multmanta"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${multmanta_qos} \
				--define cpu=${multmanta_cpu} \
				--define mem=${multmanta_mem} \
				--define time="${multmanta_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define pedDir=${pedDir} \
				--define stepDir=${stepDir} \
				--define levelId=${pedigree} \
				--define app="${app}" \
				${ttDir}/${multmanta_tt} > ${jobCmd}
				if [ "$nSampPed" -le "5" ]; then
					multmantaJobID=$(sbatch --parsable ${jobCmd})
					if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
					echo -e "${jobCmd}\t${multmantaJobID}" | tee -a ${jobLog} >&2
				else
					echo "# INFO - Too many samples (max.5, given ${nSampPed}), execution will take too much time, [${jobCmd}] not submited" | tee -a ${stepDir}/multmanta.log >&2
				fi
			else
				echo "# INFO - Only one sample for this pedigree [${pedigree}], skipping multmanta" | tee -a ${stepDir}/multmanta.log >&2
			fi
		else
			echo "# INFO - multmanta directory for pedigree [${pedigree}] already exists, skipping this step" >&2
		fi
	fi
	
	#--------------#
	# somalier     #
	#--------------#
	if [[ " ${stepuser[*]} " =~ " somalier " ]]; then
		echo "# INFO - Submitting somalier for pedigree [${pedigree}] ..." >&2
		stepDir="${pedDir}/somalier"
		if [ ! -d ${stepDir} ]; then
			mkdir -p ${stepDir}
			if [ "$nSampPed" -gt "1" ]; then
				jobLab="${pedigree}.somalier"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${somalier_qos} \
				--define cpu=${somalier_cpu} \
				--define mem=${somalier_mem} \
				--define time="${somalier_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define sheetDir=${pedDir} \
				--define levelId=${pedigree} \
				--define pedfile=${pedDir}/${pedigree}_samples_info.ped \
				${ttDir}/${somalier_tt} > ${jobCmd}
				somalierpedJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${somalierpedJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - Only one sample for this pedigree [${pedigree}], skipping somalier" | tee -a ${stepDir}/somalier.log >&2
			fi
		else
			echo "# INFO - somalier directory for pedigree [${pedigree}] already exists, skipping this step" >&2
		fi
	fi
	
done < <(grep -v "^#" [% analysisId %]_samples_info.tsv | cut -f 1 | sort -u)
allhapcallJobID=$(IFS=: ; echo "${allhapcallJobIDs[*]}")

################################################
# SUBMIT FOR WHOLE ANALYSIS                    #
################################################
nSampAna=$(grep -v "^#" [% anaDir %]/[% analysisId %]_samples_info.tsv | wc -l)

#--------------#
# allshortvar  #
#--------------#
if [[ " ${stepuser[*]} " =~ " allshortvar " ]]; then
	echo "# INFO - Submitting allshortvar ..." >&2
	stepDir="[% anaDir %]/allshortvar"
	if [ ! -d ${stepDir} ]; then
		mkdir -p ${stepDir}
		if [ "$nSampAna" -gt "1" ]; then
			jobLab="[% analysisId %].allshortvar"
			jobCmd="${stepDir}/${jobLab}.cmd"
			jobLog="${stepDir}/${jobLab}.jobID.log"
			apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
			--define qos=${allshortvar_qos} \
			--define cpu=${allshortvar_cpu} \
			--define mem=${allshortvar_mem} \
			--define time="${allshortvar_time}" \
			--define excludeNode=[% excludeNode %] \
			--define jobLab=${jobLab} \
			--define confFile=[% confFile %] \
			--define anaDir=[% anaDir %] \
			--define stepDir=${stepDir} \
			--define levelId=[% analysisId %] \
			${ttDir}/${allshortvar_tt} > ${jobCmd}
			if [ ! -z  "${allhapcallJobID}" ]; then
				allshortvarJobID=$(sbatch --dependency=afterok:${allhapcallJobID} --parsable ${jobCmd})
			else
				allshortvarJobID=$(sbatch --parsable ${jobCmd})
			fi
			if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
			echo -e "${jobCmd}\t${allshortvarJobID}" | tee -a ${jobLog} >&2
		else
			echo "# INFO - Only one sample for this analysis [[% analysisId %]], skipping allshortvar" | tee -a ${stepDir}/allshortvar.log >&2
		fi
	else
		echo "# INFO - allshortvar directory for analysis [[% analysisId %]] already exists, skipping this step" >&2
	fi
fi

#--------------#
# somalier     #
#--------------#
if [[ " ${stepuser[*]} " =~ " somalier " ]]; then
	echo "# INFO - Submitting somalier ..." >&2
	stepDir="[% anaDir %]/somalier"
	if [ ! -d ${stepDir} ]; then
		mkdir -p ${stepDir}
		if [ "$nSampAna" -gt "1" ]; then
			jobLab="[% analysisId %].somalier"
			jobCmd="${stepDir}/${jobLab}.cmd"
			jobLog="${stepDir}/${jobLab}.jobID.log"
			apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
			--define qos=${somalier_qos} \
			--define cpu=${somalier_cpu} \
			--define mem=${somalier_mem} \
			--define time="${somalier_time}" \
			--define excludeNode=[% excludeNode %] \
			--define jobLab=${jobLab} \
			--define confFile=[% confFile %] \
			--define stepDir=${stepDir} \
			--define sheetDir=[% anaDir %] \
			--define levelId=[% analysisId %] \
			--define pedfile=[% anaDir %]/[% analysisId %]_samples_info.ped \
			${ttDir}/${somalier_tt} > ${jobCmd}
			somalieranaJobID=$(sbatch --parsable ${jobCmd})
			if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
			echo -e "${jobCmd}\t${somalieranaJobID}" | tee -a ${jobLog} >&2
		else
			echo "# INFO - Only one sample for this analysis [[% analysisId %]], skipping somalier" | tee -a ${stepDir}/somalier.log >&2
		fi
	else
		echo "# INFO - somalier directory for analysis [[% analysisId %]] already exists, skipping this step" >&2
	fi
fi

#--------------#
# exdepth      #
#--------------#
if [[ " ${stepuser[*]} " =~ " exdepth " ]]; then
	echo "# INFO - Submitting exdepth by app ..." >&2
	while read app; do
		stepDir="[% anaDir %]/cnv/${app}/exdepth"
		if [ ! -d ${stepDir} ]; then
			mkdir -p ${stepDir}
			if [ "${app}" != "WGS" ]; then
				jobLab="${app}.exdepth"
				jobCmd="${stepDir}/${jobLab}.cmd"
				jobLog="${stepDir}/${jobLab}.jobID.log"
				apptainer run --no-home --bind ${bindDir} ${contDir}/${perlCont} tpage \
				--define qos=${exdepth_qos} \
				--define cpu=${exdepth_cpu} \
				--define mem=${exdepth_mem} \
				--define time="${exdepth_time}" \
				--define excludeNode=[% excludeNode %] \
				--define jobLab=${jobLab} \
				--define confFile=[% confFile %] \
				--define stepDir=${stepDir} \
				--define sheetDir=[% anaDir %] \
				--define levelId=[% analysisId %] \
				--define app="${app}" \
				${ttDir}/${exdepth_tt} > ${jobCmd}
				exdepthJobID=$(sbatch --parsable ${jobCmd})
				if [ $? != 0 ]; then echo "ERROR : Cannot submit [${jobCmd}] [${cmdFile}]" >> ${errLog}; exit 1; fi
				echo -e "${jobCmd}\t${exdepthJobID}" | tee -a ${jobLog} >&2
			else
				echo "# INFO - Experiment is [${app}], skipping exdepth" | tee -a ${stepDir}/exdepth.log >&2
			fi
		else
			echo "# INFO - exdepth directory for analysis [[% analysisId %]] and app [${app}] already exists, skipping this step" >&2
		fi
	done < <(grep -v "^#" [% analysisId %]_samples_rawdata.tsv | cut -f 3 | sort -u)
fi

echo "# INFO - Done!" >&2

printf END >&2; uptime >&2
date >&2
