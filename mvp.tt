					echo -e "${jobCmd}\t${hlakirJobID}" | tee -a ${jobLog} >&2
				else
					echo "# INFO - hlakir available only for WGS, application is [${app}], skipping hlakir for sample [${sample}]" | tee -a ${stepDir}/hlakir.log >&2
				fi
			else
				echo "# INFO - hlakir directory for pedigree [${pedigree}] and sample [${sample}] already exists, skipping this step" >&2
