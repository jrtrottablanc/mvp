#!/bin/bash
#SBATCH --exclude=[% excludeNode %]
#SBATCH --job-name=[% jobLab %]
#SBATCH --chdir=[% stepDir %]
#SBATCH --partition=genD
#SBATCH --requeue
#SBATCH --output=[% jobLab %]_%j.out 
#SBATCH --error=[% jobLab %]_%j.err 
#SBATCH --ntasks=1
#SBATCH --qos=[% qos %]
#SBATCH --cpus-per-task=[% cpu %]
#SBATCH --mem-per-cpu=[% mem %]
#SBATCH --time=[% time %]

hostname >&2
printf START >&2; uptime >&2
date >&2

export LC_ALL=C

cmdFile="[% stepDir %]/[% jobLab %].cmd"
errLog="[% stepDir %]/ERROR.log"

source [% confFile %]

echo "# INFO - Preparing manifest ..." >&2
echo [% input %] > [% levelId %]_gauchian_manifest.txt 
if [ $? != 0 ]; then echo "ERROR : gauchian [step#1] [${cmdFile}]" >> ${errLog}; exit 1; fi

echo "# INFO - Running gauchian ..." >&2
apptainer run --no-home --bind ${bindDir} ${contDir}/${gauchianCont} gauchian \
-m [% levelId %]_gauchian_manifest.txt \
-g ${gauchianDb} \
-o [% stepDir %] \
-p [% levelId %].gauchian \
-t [% cpu %] \
--reference ${fasta}
if [ $? != 0 ]; then echo "ERROR : gauchian [step#2] [${cmdFile}]" >> ${errLog}; exit 1; fi

printf END >&2; uptime >&2
date >&2
